# Copy this file to .env and fill in the values.

# Geographic coordinates of the location whose dew point you want to track.
LATITUDE=39.9870257
LONGITUDE=-75.6208719

# Local IP address of the Govee device on your network.
# Enable "LAN Control" in the Govee app (Device Settings → LAN Control) to
# allow direct local communication. Assign a static IP or DHCP reservation
# to keep this address stable.
GOVEE_DEVICE_IP=192.168.1.50
