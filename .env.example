# Copy this file to .env and fill in the values.

# Geographic coordinates of the location whose dew point you want to track.
LATITUDE=39.9870257
LONGITUDE=-75.6208719

# Govee Developer API credentials.
# Get your API key from the Govee app: Profile → About Us → Apply for API Key
GOVEE_API_KEY=your-govee-api-key-here

# Govee device info — visible in the Govee app under the device's settings.
GOVEE_DEVICE_ID=AA:BB:CC:DD:EE:FF:00:11
GOVEE_MODEL=H6159
